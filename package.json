{
  "name": "air-icon-launcher",
  "version": "0.1.10",
  "type": "module",
  "description": "A Windows desktop launcher for organizing and launching apps with categories, search, and plugin support",
  "author": "Air",
  "license": "MIT",
  "homepage": "https://github.com/your-username/air-icon-launcher#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/your-username/air-icon-launcher.git"
  },
  "bugs": {
    "url": "https://github.com/your-username/air-icon-launcher/issues"
  },
  "keywords": [
    "launcher",
    "desktop",
    "windows",
    "tauri",
    "productivity",
    "app-launcher"
  ],
  "scripts": {
    "postinstall": "node scripts/patch-solar-icons.cjs",
    "dev": "vite",
    "typecheck": "vue-tsc --noEmit",
    "check:web": "bun run typecheck && vite build",
    "check:rust": "cd src-tauri && cargo check --no-default-features",
    "check": "bun run check:web && bun run check:rust",
    "test": "cd src-tauri && cargo test --no-default-features",
    "test:unit": "vitest run",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "tauri": "tauri"
  },
  "dependencies": {
    "@solar-icons/vue": "^1.2.0",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2.6.0",
    "@tauri-apps/plugin-fs": "^2.4.5",
    "@tauri-apps/plugin-opener": "^2",
    "@vueuse/core": "^14.2.1",
    "gitnexus": "^1.6.3",
    "pinia": "^3.0.4",
    "pinia-plugin-persistedstate": "^4.7.1",
    "sass": "^1.97.3",
    "vue": "^3.5.13",
    "vue-router": "4",
    "vuedraggable": "^4.1.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@vitejs/plugin-vue": "^5.2.1",
    "typescript": "~5.6.2",
    "vite": "^6.0.3",
    "vitest": "^4.1.2",
    "vue-tsc": "^2.1.10"
  }
}
